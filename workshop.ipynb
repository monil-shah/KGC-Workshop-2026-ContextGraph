        {
          "output_type": "stream",
          "name": "stdout",
          "text": "[SUCCESS] Authenticated as: arn:aws:sts::721082559250:assumed-role/AmazonSageMakerAdminIAMExecutionRole/ea5e91fe-86aa-494c-9f27-57e69d1a2bae\n   Account: 721082559250\n   Region: us-east-2\n"
        }
      ]
